# HTML shells must never be cached long-term: they reference hashed asset
# filenames that change on every deploy. Caching them causes stale HTML to
# request bundles that no longer exist, which Cloudflare serves as index.html
# (text/html), breaking the module-script MIME check and blanking the page.
/
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

/admin.html
  Cache-Control: no-cache, must-revalidate

# Vite emits content-hashed filenames for assets, so they're safe to cache
# forever. New deploys get new hashes.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Dynamic JSON data files — always revalidate so updates are seen immediately
/news.json
  Cache-Control: no-cache, must-revalidate

/news-archive.json
  Cache-Control: no-cache, must-revalidate

/cit-cases.json
  Cache-Control: no-cache, must-revalidate

